# ── Gemini AI ────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable: Google Calendar API + Google+ API (for userinfo)
# Authorised redirect URIs: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PUB:', v.public_key); print('PRIV:', v.private_key)"
VAPID_PUBLIC_KEY=your_vapid_public_key_base64url
VAPID_PRIVATE_KEY=your_vapid_private_key_base64url
VAPID_EMAIL=admin@yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./lastminute.db
FRONTEND_URL=http://localhost:5173
SECRET_KEY=change_this_to_a_long_random_secret
