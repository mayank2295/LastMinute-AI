# ── AI (Google Gemini) ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── AI (Anthropic Claude — fallback) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google OAuth2 ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# In production this is your public domain, e.g. https://mayank.store/api/auth/callback/google
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/callback/google

# ── Firebase Firestore ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----\n"

# ── VAPID Keys for Web Push ───────────────────────────────────────────────
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_CLAIMS_EMAIL=mailto:your_email@gmail.com

# ── App ───────────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here
FRONTEND_URL=https://your-domain.com
PORT=8080

# ── OAuth scope relaxation ────────────────────────────────────────────────
OAUTHLIB_RELAX_TOKEN_SCOPE=1
